# ===========================================================
# KrishiMitra AI - Environment Configuration Template
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ===========================================================

# --- Gemini / Google AI ---
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.0-pro

# --- Weather API (e.g. OpenWeatherMap / Open-Meteo) ---
WEATHER_API_KEY=your_weather_api_key_here
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1

# --- Market price data source ---
MARKET_API_KEY=your_market_api_key_here
MARKET_API_BASE_URL=https://api.data.gov.in/resource

# --- Database ---
DATABASE_PATH=./database/krishimitra.db

# --- Security ---
SECRET_KEY=replace_with_a_long_random_string
RATE_LIMIT_PER_MINUTE=30
MAX_INPUT_LENGTH=2000
ENABLE_PROMPT_INJECTION_GUARD=true
ENABLE_PII_FILTER=true

# --- App ---
APP_ENV=development
DEFAULT_LANGUAGE=en
LOG_LEVEL=INFO
